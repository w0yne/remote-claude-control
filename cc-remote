#!/usr/bin/env python3
"""
cc-remote — install and manage the Feishu→tmux→Claude Code remote-control tool.

Subcommands:
  install            Install scripts + dirs under ~/.cc_remote, seed .env.
  setup [dir]        Configure a project dir: merge Stop hook + start tmux+claude.
  bridge start|stop|status   Manage the resident bridge (launchd).
  doctor             Self-check deps, credentials, bridge, current dir.
"""

import argparse
import json
import os
import shutil
import subprocess
import sys

HOME = os.path.expanduser("~/.cc_remote")
BIN = os.path.join(HOME, "bin")
ENV_FILE = os.path.join(HOME, ".env")
SCRIPTS = ["bridge.py", "hook_notify.py", "cc-remote"]
PACKAGE = "ccremote"  # copied recursively into BIN alongside the entrypoints
HOOK_CMD = '"${CC_HOOK_PYTHON:-python3}" "$HOME/.cc_remote/bin/hook_notify.py"'
# Placeholder values shipped in .env.example — used to detect an unedited .env.
PLACEHOLDER_MARKERS = ("cli_xxxx", "your_app_secret_here")


def _env():
    """Read ~/.cc_remote/.env into a dict via python-dotenv (same parser the
    bridge/hook use, so quotes/comments/export are handled identically).
    Returns {} if the file or dotenv is unavailable.

    Intentionally standalone (not via ccremote.config): the CLI runs from a
    source checkout BEFORE anything is installed, so the package may not be on
    sys.path yet. dotenv is the only dependency and is already required."""
    if not os.path.exists(ENV_FILE):
        return {}
    try:
        from dotenv import dotenv_values

        return {k: v for k, v in dotenv_values(ENV_FILE).items() if v is not None}
    except Exception:
        return {}


def _pybin():
    """Interpreter for the resident bridge / dep checks. CC_HOOK_PYTHON from the
    shell env wins, then from ~/.cc_remote/.env, else the current interpreter.
    (cc-remote may be launched by a python without the deps; .env is where the
    user configures the right one.)"""
    return (
        os.environ.get("CC_HOOK_PYTHON")
        or _env().get("CC_HOOK_PYTHON")
        or sys.executable
    )


def _py_has(mod, pybin=None):
    return (
        subprocess.run([pybin or _pybin(), "-c", f"import {mod}"],
                       capture_output=True).returncode == 0
    )


def _creds_look_real():
    """True if .env has non-placeholder Feishu credentials."""
    env = _env()
    app_id = env.get("FEISHU_APP_ID", "")
    secret = env.get("FEISHU_APP_SECRET", "")
    if not app_id or not secret:
        return False
    return not any(m in app_id or m in secret for m in PLACEHOLDER_MARKERS)


def _tmux_session():
    return _env().get("TMUX_SESSION") or "cc"


def _registry():
    """Import the pure-stdlib ccremote.registry from beside this script. Done
    lazily (not at top) so `install`/`doctor` still work if the package isn't
    on sys.path yet from some other cwd."""
    here = os.path.dirname(os.path.abspath(__file__))
    if here not in sys.path:
        sys.path.insert(0, here)
    from ccremote import registry
    return registry


def _backend():
    """The platform service backend (launchd on macOS, systemd on Linux).
    Imported lazily from beside this script, like _registry()."""
    here = os.path.dirname(os.path.abspath(__file__))
    if here not in sys.path:
        sys.path.insert(0, here)
    from ccremote import platform
    return platform.detect()


def _notify_deps():
    """Lazily import the lark-dependent modules notify needs, from beside this
    script (like _registry/_backend). Kept out of module import so install/
    doctor/setup/projects still run on a python without lark_oapi. Returns a
    namespace with config/feishu/tmux/chat_pointer."""
    here = os.path.dirname(os.path.abspath(__file__))
    if here not in sys.path:
        sys.path.insert(0, here)
    import types as _types
    from ccremote import chat_pointer, config, feishu, tmux
    return _types.SimpleNamespace(config=config, feishu=feishu, tmux=tmux,
                                  chat_pointer=chat_pointer)


def _resolve_notify_content(args, stdin):
    """Notify message text: the positional arg if non-empty, else stdin, else
    None. Whitespace-only counts as empty."""
    if args.message and args.message.strip():
        return args.message.strip()
    data = stdin.read().strip()
    return data or None


def _resolve_notify_target(args, current_session, base_dir):
    """Resolve the chat_id notify sends to. Returns (chat_id, err): exactly one
    is None. --chat wins; else the current tmux session's chat pointer; else an
    error message explaining what went wrong."""
    from ccremote import chat_pointer
    if args.chat:
        return (args.chat, None)
    session = current_session()
    if not session:
        return (None, "not inside a tmux session (and no --chat given); "
                      "cc-remote notify must run in a controlled session")
    chat_id = chat_pointer.read(base_dir, session)
    if not chat_id:
        return (None, f"no chat has driven session '{session}' yet "
                      f"(no pointer at sessions/{session}/chat); "
                      f"send a message from Feishu first, or pass --chat")
    return (chat_id, None)


def _session_alive(session):
    """tmux has-session check (stdlib subprocess; no ccremote import needed)."""
    return subprocess.run(["tmux", "has-session", "-t", session],
                          capture_output=True).returncode == 0


def _registry_summary():
    """One-line summary of the multi-project registry for doctor: how many
    projects registered, which session is active, and whether it's live."""
    registry = _registry()
    reg = registry.load(HOME)
    active = registry.read_active(HOME)
    if not reg:
        return "0 projects registered (single-session mode); active="\
               f"{active or '(default ' + _tmux_session() + ')'}"
    live = "live" if active and _session_alive(active) else "dead/none"
    return (f"{len(reg)} projects registered; "
            f"active session={active or '(default ' + _tmux_session() + ')'} [{live}]")


def cmd_projects(args):
    """Manage the multi-project registry. NEVER touches any .claude/settings.json
    or any tmux session — `add` just records an already-running session, which
    is how the current cc session gets registered without re-running setup on
    it. Subcommands: list / add / rm."""
    registry = _registry()
    if args.action == "list":
        reg = registry.load(HOME)
        if not reg:
            print("（无已注册项目）用 `cc-remote setup --name <别名>` 登记，"
                  "或 `cc-remote projects add <别名> --session <s> --dir <d>`。")
            return 0
        active = registry.read_active(HOME)
        for alias in sorted(reg):
            p = reg[alias]
            sess = p.get("session")
            star = "★" if sess == active else " "
            dot = "●live" if _session_alive(sess) else "○dead"
            print(f"{star} {alias}  [{dot}]  session={sess}  dir={p.get('dir')}")
        return 0

    if args.action == "add":
        registry.add(HOME, args.alias, session=args.session, dir=args.dir)
        print(f"✅ 已登记项目 '{args.alias}' → session {args.session}, dir {args.dir}")
        print("   (仅写注册表，未触碰 .claude/settings.json 或任何 tmux session)")
        return 0

    if args.action == "rm":
        ok = registry.remove(HOME, args.alias)
        print(f"✅ 已移除 '{args.alias}'" if ok else f"⚠️ 未注册的项目 '{args.alias}'")
        return 0

    print(f"未知 projects 子命令: {args.action}")
    return 1


def cmd_install(args):
    src_dir = os.path.dirname(os.path.abspath(__file__))
    for d in [HOME, BIN,
              os.path.join(HOME, "images"),
              os.path.join(HOME, "signals"),
              os.path.join(HOME, "screenshots")]:
        os.makedirs(d, exist_ok=True)

    # Copy the ccremote package (entrypoints import it from beside them).
    src_pkg = os.path.join(src_dir, PACKAGE)
    dst_pkg = os.path.join(BIN, PACKAGE)
    if os.path.isdir(src_pkg):
        if os.path.abspath(src_pkg) != os.path.abspath(dst_pkg):
            shutil.rmtree(dst_pkg, ignore_errors=True)
            shutil.copytree(src_pkg, dst_pkg,
                            ignore=shutil.ignore_patterns("__pycache__", "*.pyc"))
        print(f"✅ installed package → {dst_pkg}")
    else:
        print(f"⚠️  package dir missing, skipped: {src_pkg}")

    # Copy scripts from the source checkout into ~/.cc_remote/bin.
    copied = []
    for s in SCRIPTS:
        src = os.path.join(src_dir, s)
        if not os.path.exists(src):
            print(f"⚠️  source missing, skipped: {s}")
            continue
        dst = os.path.join(BIN, s)
        # Don't copy a file onto itself (e.g. running the installed cc-remote).
        if os.path.abspath(src) != os.path.abspath(dst):
            shutil.copy2(src, dst)
        if s.endswith(".py") or s == "cc-remote":
            os.chmod(dst, 0o755)
        copied.append(s)
    print(f"✅ installed scripts → {BIN}: {', '.join(copied)}")

    # Seed .env from the repo's example if absent.
    if not os.path.exists(ENV_FILE):
        example = os.path.join(src_dir, ".env.example")
        if os.path.exists(example):
            shutil.copy2(example, ENV_FILE)
            print(f"✅ seeded {ENV_FILE} from .env.example — FILL IN your Feishu creds")
        else:
            print(f"⚠️  no .env.example found; create {ENV_FILE} manually")
    else:
        print(f"ℹ️  kept existing {ENV_FILE}")

    # Dependency hints (platform-aware: brew on macOS, dnf/apt on Linux).
    backend = _backend()
    for tool, hint in backend.tool_hints():
        if not shutil.which(tool):
            print(f"⚠️  missing {tool} → {hint}")
    if not _py_has("lark_oapi") or not _py_has("dotenv"):
        print(f"⚠️  missing python deps → {backend.python_dep_note()}")

    print("\nNext:")
    print(f"  1. Fill in {ENV_FILE} (Feishu APP_ID/SECRET, ALLOWED_USERS)")
    print(f"  2. Add to PATH:  export PATH=\"$HOME/.cc_remote/bin:$PATH\"")
    print(f"  3. cc-remote bridge start")
    print(f"  4. cd <project> && cc-remote setup")
    return 0


def cmd_setup(args):
    target = os.path.abspath(args.dir)
    if not os.path.isdir(target):
        print(f"❌ not a directory: {target}")
        return 1
    # The hook entrypoint AND the package it imports must both be installed;
    # checking only the entrypoint would let setup configure a hook that then
    # crashes with ModuleNotFoundError if a prior install copied incompletely.
    if not os.path.exists(os.path.join(BIN, "hook_notify.py")) or \
       not os.path.exists(os.path.join(BIN, PACKAGE, "__init__.py")):
        print("❌ not installed (or install incomplete) — run: cc-remote install")
        return 1

    claude_dir = os.path.join(target, ".claude")
    os.makedirs(claude_dir, exist_ok=True)
    settings = os.path.join(claude_dir, "settings.json")

    data = {}
    if os.path.exists(settings):
        try:
            with open(settings) as f:
                data = json.load(f)
        except Exception as e:
            print(f"❌ existing {settings} is not valid JSON ({e}); not touching it")
            return 1

    # Merge deny rule (idempotent).
    perms = data.setdefault("permissions", {})
    deny = perms.setdefault("deny", [])
    if "AskUserQuestion" not in deny:
        deny.append("AskUserQuestion")

    # Merge Stop hook (idempotent). Match by the hook_notify.py path, not the
    # exact command string, so a future tweak to HOOK_CMD updates in place
    # instead of appending a duplicate hook that double-fires.
    hooks = data.setdefault("hooks", {})
    stop = hooks.setdefault("Stop", [])
    HOOK_MARK = "hook_notify.py"
    already = any(
        HOOK_MARK in (h.get("command") or "")
        for group in stop if isinstance(group, dict)
        for h in (group.get("hooks") or []) if isinstance(h, dict)
    )
    if not already:
        stop.append({"hooks": [{"type": "command", "command": HOOK_CMD}]})

    tmp = settings + ".tmp"
    try:
        with open(tmp, "w") as f:
            json.dump(data, f, indent=2)
            f.write("\n")
        os.replace(tmp, settings)
    finally:
        if os.path.exists(tmp):
            os.remove(tmp)
    print(f"✅ configured {settings} (Stop hook + deny AskUserQuestion)")

    # The command used to launch Claude inside tmux. Precedence:
    #   --claude-cmd flag  >  CLAUDE_CMD in ~/.cc_remote/.env  >  "claude"
    # Put your usual flags (e.g. --dangerously-skip-permissions) in CLAUDE_CMD
    # once, so remote sessions don't get stuck on permission prompts.
    claude_cmd = args.claude_cmd or _env().get("CLAUDE_CMD") or "claude"
    # Session name precedence: --session > (alias when --name given) > .env default.
    name = getattr(args, "name", None)
    session = getattr(args, "session", None) or (name if name else None) or _tmux_session()

    # Register in the multi-project registry when --name is given, so /switch
    # and /projects can see this project. (No --name → legacy single-session
    # behavior, no registry entry.)
    if name:
        registry = _registry()
        registry.add(HOME, name, session=session, dir=target)
        print(f"✅ registered project '{name}' → session {session} (for /switch)")

    if args.no_launch:
        print(f"ℹ️  --no-launch: hook configured; not starting tmux/claude.")
        print(f"    Start it yourself:  tmux new-session -s {session} -c {target}"
              f"   # then: {claude_cmd}")
        return 0

    if not shutil.which("tmux"):
        print("⚠️  tmux not found — hook is configured, but start tmux+claude yourself"
              " once tmux is installed (brew install tmux).")
        return 0

    exists = subprocess.run(["tmux", "has-session", "-t", session],
                            capture_output=True).returncode == 0
    if not exists:
        try:
            subprocess.run(["tmux", "new-session", "-d", "-s", session, "-c", target],
                           check=True)
            # Brief settle so the shell prompt is ready before we type the cmd.
            subprocess.run(["sleep", "0.5"])
            # -l sends the command line literally; Enter runs it.
            subprocess.run(["tmux", "send-keys", "-t", session, "-l", claude_cmd],
                           check=True)
            subprocess.run(["tmux", "send-keys", "-t", session, "Enter"], check=True)
        except subprocess.CalledProcessError as e:
            print(f"⚠️  tmux setup failed ({e}); hook is configured. Start manually:")
            print(f"    tmux new-session -s {session} -c {target}  # then: {claude_cmd}")
            return 0
        print(f"✅ created tmux session '{session}' in {target} and launched: {claude_cmd}")
        print(f"   (verify it launched: tmux attach -t {session} — if you see a"
              f" shell prompt, run '{claude_cmd}' yourself)")
    else:
        print(f"ℹ️  tmux session '{session}' already exists — left as is")
        print(f"   (attach with: tmux attach -t {session})")

    print(f"\nReady. Attach locally:  tmux attach -t {session}")
    print("Then drive it from Feishu. Bridge running? cc-remote bridge status")
    return 0


def cmd_bridge(args):
    backend = _backend()
    if args.action == "status":
        st = backend.state()
        print(f"service {backend.service_label}: {'loaded' if st.loaded else 'not loaded'}")
        print(f"bridge process: {'running (PID ' + str(st.pid) + ')' if st.running else 'not running'}")
        if st.loaded and not st.running and st.last_exit not in (None, 0):
            print(f"⚠️  last exit status {st.last_exit} — bridge crashed; check the log")
        if st.note:
            print(f"ℹ️  {st.note}")
        stray = backend.stray_processes(managed_pid=st.pid)
        if stray:
            print(f"⚠️  stray (unmanaged) bridge process(es): {', '.join(stray)}")
            print(f"    kill them to avoid two bridges fighting one Feishu app:  kill {' '.join(stray)}")
        print(f"log: {os.path.join(HOME, 'bridge.log')}")
        return 0

    if args.action == "start":
        if not os.path.exists(os.path.join(BIN, "bridge.py")):
            print("❌ not installed — run: cc-remote install")
            return 1
        pybin = _pybin()
        if not _py_has("lark_oapi", pybin):
            print(f"❌ interpreter {pybin} can't import lark_oapi.")
            print("   Set CC_HOOK_PYTHON (in ~/.cc_remote/.env or the shell) to a")
            print(f"   python that has the deps:  {backend.python_dep_note()}")
            return 1
        if not _creds_look_real():
            print("❌ ~/.cc_remote/.env has missing or placeholder Feishu creds.")
            print("   Fill FEISHU_APP_ID / FEISHU_APP_SECRET before starting.")
            return 1
        stray = backend.stray_processes()
        if stray:
            print(f"⚠️  killing stray (unmanaged) bridge(s): {', '.join(stray)}")
            subprocess.run(["kill"] + stray, capture_output=True)
        bridge_py = os.path.join(BIN, "bridge.py")
        log_out = os.path.join(HOME, "bridge.log")
        res = backend.start(pybin=pybin, bridge_py=bridge_py, workdir=HOME,
                            env_file=ENV_FILE, log_path=log_out)
        if not res.ok:
            print(f"⚠️ {res.message}")
            print(f"   check {log_out}")
            return 1
        print(f"✅ bridge {res.message} (interpreter: {pybin})")
        print(f"   log: {log_out}")
        return 0

    if args.action == "stop":
        res = backend.stop()
        print(f"✅ bridge stopped" if res.ok else f"⚠️  {res.message}")
        # Service is down now, so any surviving bridge.py is by definition a
        # stray; managed_pid=None both says that and skips a redundant state().
        stray = backend.stray_processes(managed_pid=None)
        if stray:
            print(f"⚠️  stray (unmanaged) bridge(s) still running: {', '.join(stray)}")
            print(f"    kill {' '.join(stray)}")
        return 0


def cmd_doctor(args):
    print("cc-remote doctor\n" + "-" * 40)
    ok = True

    def check(label, good, hint=""):
        nonlocal ok
        mark = "✅" if good else "❌"
        print(f"{mark} {label}" + (f"  → {hint}" if not good and hint else ""))
        if not good:
            ok = False

    check(f"home dir {HOME}", os.path.isdir(HOME), "run: cc-remote install")
    check(f"scripts in {BIN}",
          all(os.path.exists(os.path.join(BIN, s)) for s in SCRIPTS),
          "run: cc-remote install")
    check(f"{PACKAGE} package in {BIN}",
          os.path.exists(os.path.join(BIN, PACKAGE, "__init__.py")),
          "run: cc-remote install")
    check(f".env at {ENV_FILE}", os.path.exists(ENV_FILE),
          "run: cc-remote install, then fill it")
    check("Feishu creds filled (not placeholder)", _creds_look_real(),
          f"edit {ENV_FILE}: real FEISHU_APP_ID / FEISHU_APP_SECRET")
    backend = _backend()
    for tool, hint in backend.tool_hints():
        check(f"{tool} installed", bool(shutil.which(tool)), hint)
    # The thing we actually drive: the launcher from CLAUDE_CMD (default "claude").
    # First token so "claude --resume ..." or an absolute path both resolve.
    claude_bin = (_env().get("CLAUDE_CMD") or "claude").split()[0]
    check(f"claude launcher on PATH ({claude_bin})", bool(shutil.which(claude_bin)),
          "install & log in to Claude Code first (npm i -g @anthropic-ai/claude-code), "
          "or set CLAUDE_CMD in ~/.cc_remote/.env")
    pybin = _pybin()
    # lark_oapi and python-dotenv are the two bridge deps; both come from the
    # same install step, so one platform-aware hint covers either being absent.
    check(f"bridge interpreter has lark_oapi + dotenv ({pybin})",
          _py_has("lark_oapi", pybin) and _py_has("dotenv", pybin),
          backend.python_dep_note())
    st = backend.state()
    check("bridge running", st.loaded and st.running, "run: cc-remote bridge start")
    if st.running:
        print(f"   bridge PID: {st.pid}")
    elif st.loaded and st.last_exit not in (None, 0):
        print(f"   ⚠️ service loaded but not running (last exit {st.last_exit}) — crashed")
    if st.note:
        print(f"   ℹ️ {st.note}")
    stray = backend.stray_processes(managed_pid=st.pid)
    if stray:
        print(f"   ⚠️ stray (unmanaged) bridge(s): {', '.join(stray)} (kill to avoid conflicts)")
    # OS-specific doctor checks (e.g. Linux locale). CLI stays platform-agnostic.
    for label, good, hint in backend.health_warnings():
        check(label, good, hint)

    # Current dir configured for the hook? Match OUR hook command, not just any
    # Stop hook. Gated into `ok` via check().
    cwd_hook = os.path.join(os.getcwd(), ".claude", "settings.json")
    has_our_hook = False
    if os.path.exists(cwd_hook):
        try:
            with open(cwd_hook) as f:
                d = json.load(f)
            has_our_hook = any(
                "hook_notify.py" in (h.get("command") or "")
                for g in (d.get("hooks") or {}).get("Stop", []) if isinstance(g, dict)
                for h in (g.get("hooks") or []) if isinstance(h, dict)
            )
        except Exception:
            pass
    check("current dir configured for hook", has_our_hook, "run: cc-remote setup")
    print(f"ℹ️  registry: {_registry_summary()}")
    print("-" * 40)
    print("All core checks passed." if ok else "Some checks failed — see hints above.")
    return 0 if ok else 1


def cmd_notify(args):
    """Send a proactive notification card back to the Feishu chat that drives
    this tmux session. Independent of the Stop hook — for telling the user a
    background task finished after the turn already returned."""
    try:
        deps = _notify_deps()
    except Exception as e:
        print(f"❌ notify needs lark_oapi + python-dotenv. Use an interpreter "
              f"that has them, e.g.\n"
              f"   ~/.pyenv/versions/3.11.11/bin/python3 ~/.cc_remote/bin/cc-remote notify ...\n"
              f"   (import error: {e})", file=sys.stderr)
        return 1
    deps.config.load_env()
    if not deps.config.APP_ID or not deps.config.APP_SECRET:
        print("❌ missing Feishu creds in ~/.cc_remote/.env "
              "(FEISHU_APP_ID / FEISHU_APP_SECRET)", file=sys.stderr)
        return 1
    content = _resolve_notify_content(args, sys.stdin)
    if content is None:
        print("❌ no message: pass it as an argument or pipe via stdin\n"
              '   cc-remote notify "task done"   |   echo "..." | cc-remote notify',
              file=sys.stderr)
        return 1
    chat_id, err = _resolve_notify_target(
        args, deps.tmux.current_session, deps.config.CC_REMOTE_DIR)
    if err:
        print(f"❌ {err}", file=sys.stderr)
        return 1
    # Truncate to the card / text-fallback ceilings (same limits the hook uses).
    card_limit = deps.config.MAX_CARD_CHARS
    text_limit = deps.config.MAX_TEXT_CHARS
    card_md = content if card_limit <= 0 or len(content) <= card_limit \
        else content[:card_limit] + "\n…（已截断）"
    text_fb = content if text_limit <= 0 or len(content) <= text_limit \
        else content[:text_limit] + "\n…（已截断）"
    title = args.title or "🔔 任务通知"
    client = deps.feishu.build_client(deps.config.APP_ID, deps.config.APP_SECRET)
    ok = deps.feishu.send_markdown(client, chat_id, card_md, text_fb,
                                   header_title=title)
    if not ok:
        print(f"❌ send failed (chat {chat_id})", file=sys.stderr)
        return 1
    print(f"✅ notified chat {chat_id}")
    return 0


def main():
    p = argparse.ArgumentParser(
        prog="cc-remote", description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter)
    sub = p.add_subparsers(dest="cmd", required=True)

    sub.add_parser("install", help="Install scripts + dirs under ~/.cc_remote")

    sp = sub.add_parser("setup", help="Configure a project dir for remote control")
    sp.add_argument("dir", nargs="?", default=".", help="Target dir (default: cwd)")
    sp.add_argument("--claude-cmd", default=None,
                    help="Command to launch Claude in tmux (overrides CLAUDE_CMD "
                         "in .env; default 'claude')")
    sp.add_argument("--no-launch", action="store_true",
                    help="Only configure the hook; don't start tmux/claude")
    sp.add_argument("--name", default=None,
                    help="Register this project under this alias for /switch "
                         "(omit to keep legacy single-session behavior)")
    sp.add_argument("--session", default=None,
                    help="tmux session name for this project (default: the "
                         "--name alias, else TMUX_SESSION)")

    bp = sub.add_parser("bridge", help="Manage the resident bridge")
    bp.add_argument("action", choices=["start", "stop", "status"])

    pp = sub.add_parser("projects", help="Manage the multi-project registry")
    psub = pp.add_subparsers(dest="action", required=True)
    psub.add_parser("list", help="List registered projects + live status")
    pa = psub.add_parser("add", help="Register an already-running session "
                                     "(does NOT touch settings.json / tmux)")
    pa.add_argument("alias", help="Project alias for /switch")
    pa.add_argument("--session", required=True, help="tmux session name")
    pa.add_argument("--dir", required=True, help="Project working dir (abs path)")
    pr = psub.add_parser("rm", help="Unregister a project")
    pr.add_argument("alias")

    sub.add_parser("doctor", help="Self-check")

    np = sub.add_parser("notify", help="Send a proactive notification card to "
                                       "the Feishu chat driving this tmux session")
    np.add_argument("message", nargs="?", default=None,
                    help="Notification text (markdown). Omit to read from stdin.")
    np.add_argument("--title", default=None,
                    help="Card header (default: '🔔 任务通知')")
    np.add_argument("--chat", default=None,
                    help="Explicit chat_id target (overrides session pointer)")

    args = p.parse_args()
    handlers = {
        "install": cmd_install,
        "setup": cmd_setup,
        "bridge": cmd_bridge,
        "projects": cmd_projects,
        "doctor": cmd_doctor,
        "notify": cmd_notify,
    }
    sys.exit(handlers[args.cmd](args) or 0)


if __name__ == "__main__":
    main()
