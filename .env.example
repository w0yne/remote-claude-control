# 飞书应用凭证
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=your_app_secret_here

# 允许发送命令的用户 open_id（逗号分隔，留空则允许所有人）
ALLOWED_USERS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# tmux session 名称（Claude Code 必须运行在这个 session 里，截图/转发都针对它）
TMUX_SESSION=cc

# cc-remote setup 在 tmux 里启动 Claude 用的命令。把你常用的参数写在这里，
# 尤其远程遥控需要 --dangerously-skip-permissions（否则会卡在你手机上点不了的
# 权限确认弹窗）。setup 的 --claude-cmd 可临时覆盖；--no-launch 则完全不启动。
CLAUDE_CMD=claude --dangerously-skip-permissions

# 统一工作目录：下设 images/(收到的图片) signals/(每命令一个信号文件)
# screenshots/(终端截图)。支持 ~ 和绝对路径。需要 im:resource(收图) 权限
CC_REMOTE_DIR=~/.cc_remote

# 命令转发后给消息贴的 reaction：处理中 / 完成 / 失败。
# 合法 emoji_type 见飞书「表情文案说明」文档
REACTION_PROCESSING=OnIt
REACTION_DONE=DONE
REACTION_ERROR=CrossMark

# Stop hook 截取终端的行数。0 = 只截当前可见屏（高度固定，TUI 最稳定）；
# >0 = 额外包含这么多行滚动历史
CAPTURE_LINES=0

# 截图发飞书前转 WebP 的质量(0-100)。80 在保清晰度的同时把体积压到约 1/3
WEBP_QUALITY=80

# screenshots/ 目录最多保留多少张近期截图（下界 1）
KEEP_SCREENSHOTS=12

# 信号文件超过这么多秒未被消费即视为过期丢弃，防止残留信号误触发后续 turn
SIGNAL_TTL_SEC=1800

# 飞书 WebSocket 至少投递一次:handler 处理慢(如 /read 截图)会错过 ACK 导致重投。
# 同一 message_id 在这么多秒内的重复事件会被去重丢弃,避免一条 /read 返回多张图。
SEEN_TTL_SEC=300

# Stop hook 在截图前，把 Claude 最后一条回复发回飞书（默认为富文本卡片，见下方
# 卡片配置）。卡片发送失败时降级为纯文本，此值是纯文本降级路径的字符上限
# （超出截断，完整内容看截图）。设 0 = 不发文字、只发图
MAX_TEXT_CHARS=4000

# 回复以飞书消息卡片（card JSON v2 markdown）发送时可容纳的字符上限。卡片比纯文本
# 能装更多，故单列一个上限（默认 8000，保守值）；超出同样截断并提示看截图
MAX_CARD_CHARS=8000

# 回复卡片底部是否带一行状态页脚（仿 Claude Code statusline）：
# 🤖 <模型> · ctx <占比>% (<已用>/<上限>) · ⎇ <分支>。false/0/no/off 关闭整行页脚
CARD_FOOTER=true

# 上面页脚里上下文占比的分母（上下文窗口大小）。transcript 不含窗口大小标记，故由此
# 配置提供。默认 200000；若你用 1M 上下文的模型，设为 1000000 占比才准确
CONTEXT_WINDOW_SIZE=200000

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# （可选）Stop hook 用哪个 python 解释器，默认 PATH 上的 python3。
# 若 python3 不带 lark_oapi 依赖，设为带依赖的解释器绝对路径。
# 注意：这是供 .claude/settings.json 的 hook 命令读取的 shell 环境变量，
# 需 export 到运行 Claude Code 的环境，而非仅写在本 .env 里。
# CC_HOOK_PYTHON=/Users/you/.pyenv/versions/3.11.11/bin/python3
