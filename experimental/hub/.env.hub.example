# ============================
# Hub 配置 (.env on hub machine)
# ============================

# 飞书应用凭证
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=your_app_secret_here

# Hub WebSocket 服务端口（agents 连接用）
HUB_PORT=9800

# Agent 认证 token（Hub 和所有 Agent 必须一致）
HUB_TOKEN=changeme_to_a_random_string

# 允许发送命令的飞书用户 open_id（逗号分隔，留空则允许所有人）
ALLOWED_USERS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 转发成功后是否回复「✅ 已发送」确认（需要 im:message:send_as_bot 权限）
CONFIRM_SEND=true

LOG_LEVEL=INFO
