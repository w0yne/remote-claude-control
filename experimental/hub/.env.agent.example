# ============================
# Agent 配置 (.env on each remote machine)
# ============================

# Hub 地址（Hub 机器的 IP/域名 + 端口）
HUB_URL=ws://192.168.1.100:9800/ws

# Agent 认证 token（必须和 Hub 一致）
HUB_TOKEN=changeme_to_a_random_string

# 本机的名称（用于 /use 切换，每台机器不同）
AGENT_NAME=work

# tmux session 名称
TMUX_SESSION=cc

LOG_LEVEL=INFO
RECONNECT_INTERVAL=5
